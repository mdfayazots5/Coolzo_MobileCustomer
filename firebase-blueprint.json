{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "membershipStatus": { "type": "string", "enum": ["none", "residential", "corporate"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "hasCompletedOnboarding": { "type": "boolean" }
      },
      "required": ["uid", "email"]
    },
    "Service": {
      "title": "Service",
      "description": "Available AC services",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "duration": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string", "format": "uri" },
        "included": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Job": {
      "title": "Job",
      "description": "Service booking and tracking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "srNumber": { "type": "string" },
        "userId": { "type": "string" },
        "serviceType": { "type": "string" },
        "status": { "type": "string", "enum": ["Booked", "Assigned", "En Route", "Arrived", "In Progress", "Completed", "Cancelled"] },
        "date": { "type": "string", "format": "date" },
        "timeSlot": { "type": "string" },
        "technicianId": { "type": "string" },
        "equipmentId": { "type": "string" },
        "address": { "type": "string" },
        "price": { "type": "number" },
        "isEmergency": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Equipment": {
      "title": "Equipment",
      "description": "User's AC units",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "type": { "type": "string" },
        "capacity": { "type": "string" },
        "location": { "type": "string" },
        "installYear": { "type": "number" },
        "serialNumber": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Catalog of services"
    },
    "/jobs/{jobId}": {
      "schema": "Job",
      "description": "Service bookings"
    },
    "/users/{userId}/equipment/{equipmentId}": {
      "schema": "Equipment",
      "description": "User's registered equipment"
    }
  }
}
